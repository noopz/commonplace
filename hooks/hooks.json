{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/package.json\" \"${CLAUDE_PLUGIN_DATA}/package.json\" >/dev/null 2>&1 || (cd \"${CLAUDE_PLUGIN_ROOT}\" && npm install --production 2>&1 && cp package.json \"${CLAUDE_PLUGIN_DATA}/package.json\") || rm -f \"${CLAUDE_PLUGIN_DATA}/package.json\""
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace index --incremental 2>&1 || true"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace score 2>&1 || true"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace prune 2>&1 || true"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace lint --instruct 2>&1 || true"
          },
          {
            "type": "command",
            "command": "echo '=== Recent plugin activity ===' && node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace log --tail 60 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace raw --instruct 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace session-context 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace post-write"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commonplace post-write-research"
          }
        ]
      }
    ]
  }
}
